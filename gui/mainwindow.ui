    color: #111827;
}
QLabel#lblSubtitle {
    font-size: 12px;
    color: #6B7280;
}
QLabel#lblSection {
    font-size: 13px;
    font-weight: bold;
    color: #4B5563;
    margin-top: 15px;
}
QSpinBox {
    padding: 6px;
    padding-right: 28px;
    border: 1px solid #D1D5DB;
    border-radius: 6px;
    font-size: 14px;
    color: #111827;
    background: white;
    selection-background-color: #3B82F6;
    selection-color: white;
}
QSpinBox::up-button {
    subcontrol-origin: border;
    subcontrol-position: top right;
    width: 24px;
    height: 14px;
    border-left: 1px solid #D1D5DB;
    border-bottom: 1px solid #E5E7EB;
    border-top-right-radius: 6px;
    background: #F3F4F6;
}
QSpinBox::up-button:hover { background: #DBEAFE; }
QSpinBox::up-button:pressed { background: #BFDBFE; }
QSpinBox::up-arrow { width: 8px; height: 8px; }
QSpinBox::down-button {
    subcontrol-origin: border;
    subcontrol-position: bottom right;
    width: 24px;
    height: 14px;
    border-left: 1px solid #D1D5DB;
    border-top: 1px solid #E5E7EB;
    border-bottom-right-radius: 6px;
    background: #F3F4F6;
}
QSpinBox::down-button:hover { background: #DBEAFE; }
QSpinBox::down-button:pressed { background: #BFDBFE; }
QSpinBox::down-arrow { width: 8px; height: 8px; }
QGraphicsView {
    border: none;
    background-color: #F8F9FA;
}
