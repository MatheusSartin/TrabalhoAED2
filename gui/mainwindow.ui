    padding: 10px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#btnCalcular:hover { background-color: #059669; }
QPushButton#btnLimpar {
    background-color: #E11D48;
    color: white;
    border-radius: 6px;
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#btnLimpar:hover { background-color: #BE123C; }
QPushButton#btnCopiarImagem {
    background-color: #4B5563;
    color: white;
    border-radius: 6px;
    padding: 10px;
    font-weight: bold;
    font-size: 13px;
}
QPushButton#btnCopiarImagem:hover { background-color: #374151; }
QLabel#lblTitle  { font-size: 17px; font-weight: bold; color: #A8FF78; }
QLabel#lblSubtitle { font-size: 11px; color: #6B7280; }
QLabel { color: #B8B8FF; }
QSpinBox {
    background-color: #1A1A2E;
    color: #E0E0E0;
    border: 1px solid #3D3D8E;
    border-radius: 4px;
    padding: 4px 8px;
}
QSpinBox:focus { border-color: #A8FF78; }
QLineEdit {
    background-color: #1A1A2E;
    color: #E0E0E0;
    border: 1px solid #3D3D8E;
    border-radius: 4px;
    padding: 4px 8px;
}
QLineEdit:focus { border-color: #A8FF78; }
QGraphicsView { border: none; background-color: #0A0A1A; }
QListWidget {
    background-color: #1A1A2E;
    color: #E0E0E0;
    border: 1px solid #2D2D5E;
    border-radius: 6px;
    font-family: "Monospace";
    font-size: 11px;
}
QListWidget::item { padding: 2px 4px; }
QListWidget::item:selected { background-color: #3D3D8E; color: white; }
